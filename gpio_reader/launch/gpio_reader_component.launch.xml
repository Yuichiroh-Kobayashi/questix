<?xml version="1.0"?>
<!--
GPIO Reader component-container launch (XML)
パラメータは gpio_reader.yaml が Single Source of Truth。
-->
<launch>
  <arg name="config_file"
       default="$(find-pkg-share gpio_reader)/config/gpio_reader.yaml"
       description="Path to the GPIO reader configuration file" />

  <!-- GPIO Reader Container -->
  <node_container pkg="rclcpp_components"
                  exec="component_container"
                  name="gpio_reader_container"
                  namespace=""
                  output="screen">
    <composable_node pkg="gpio_reader"
                     plugin="gpio_reader::GpioReaderComponent"
                     name="gpio_reader_node">
      <param from="$(var config_file)" />
      <extra_arg name="use_intra_process_comms" value="true" />
    </composable_node>
  </node_container>
</launch>
