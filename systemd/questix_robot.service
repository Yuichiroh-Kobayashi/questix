[Unit]
Description=Questix Robot ROS2 Launch Service
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=ubuntu
Group=ubuntu
EnvironmentFile=-/etc/questix_robot/launch.env
ExecStart=/opt/questix_robot/questix_robot_launcher.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=questix_robot

# Graceful shutdown
TimeoutStopSec=15
KillMode=mixed
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
