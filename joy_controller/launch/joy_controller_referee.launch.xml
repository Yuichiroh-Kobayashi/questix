<?xml version="1.0"?>
<!--
Joy Controller (referee/GPIO ref) launch file
YAML が Single Source of Truth。個別パラメータの launch 引数は廃止。
GPIO ref モードでは joy_topic = /joy_gated をデフォルトとする (唯一のインライン override)。
-->
<launch>
    <arg name="dual_stick" default="false" description="Use dual stick differential drive mode" />
    <arg name="config_file"
         default="$(find-pkg-share joy_controller)/config/joy_controller_params.yaml"
         description="Path to the joy_controller configuration YAML" />
    <arg name="joy_node_config_file"
         default="$(find-pkg-share joy_controller)/config/joy_node_params.yaml"
         description="Path to the joy_node configuration YAML" />
    <arg name="uart_config_file"
         default="$(find-pkg-share uart_joy_driver)/config/uart_joy_driver_params.yaml"
         description="Path to the UART joy driver configuration YAML" />
    <arg name="joy_gate_config_file"
         default="$(find-pkg-share joy_gate)/config/joy_gate.yaml"
         description="Path to the joy_gate configuration YAML" />
    <arg name="operation_manager_config_file"
         default="$(find-pkg-share operation_manager)/config/operation_manager.yaml"
         description="Path to the operation_manager configuration YAML" />
    <arg name="controller_type" default="uart" description="Controller type: dualshock or uart" />
    <arg name="joy_topic" default="/joy_gated" description="Joy input topic (override only)" />

    <!-- Joy node (from joy package) - DualShock mode -->
    <group unless="$(equals '$(var controller_type)' 'uart')">
        <node pkg="joy" exec="joy_node" name="joy_node" output="screen">
            <param from="$(var joy_node_config_file)" />
        </node>
    </group>

    <!-- UART Joy Driver node - UART mode -->
    <group if="$(equals '$(var controller_type)' 'uart')">
        <node pkg="uart_joy_driver" exec="uart_joy_driver_node" name="uart_joy_driver" output="screen">
            <param from="$(var uart_config_file)" />
        </node>
    </group>

    <!-- Joy Gate node -->
    <node pkg="joy_gate" exec="joy_gate_node" name="joy_gate" output="screen">
        <param from="$(var joy_gate_config_file)" />
    </node>

    <!-- Joy controller node (single stick mode) -->
    <node pkg="joy_controller" exec="joy_controller_node" name="joy_controller" output="screen" unless="$(var dual_stick)">
        <param from="$(var config_file)" />
        <param name="joy_topic" value="$(var joy_topic)" />
    </node>

    <!-- Joy controller dual stick node (dual stick mode) -->
    <node pkg="joy_controller" exec="joy_controller_dual_stick_node" name="joy_controller_dual_stick" output="screen" if="$(var dual_stick)">
        <param from="$(var config_file)" />
        <param name="joy_topic" value="$(var joy_topic)" />
    </node>

    <!-- Operation Manager Node -->
    <node pkg="operation_manager" exec="operation_manager_node" name="operation_manager_node" output="screen">
        <param from="$(var operation_manager_config_file)" />
    </node>
</launch>
