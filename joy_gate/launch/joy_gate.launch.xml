<?xml version="1.0"?>
<!--
Joy Gate standalone launch file
パラメータは joy_gate.yaml が Single Source of Truth。
launch は config_file 切替と log_level のみ受け付ける。
-->
<launch>
  <arg name="config_file"
       default="$(find-pkg-share joy_gate)/config/joy_gate.yaml"
       description="Path to the joy gate configuration YAML" />
  <arg name="log_level"
       default="info"
       description="Log level (debug, info, warn, error, fatal)" />

  <node pkg="joy_gate"
        exec="joy_gate_node"
        name="joy_gate"
        output="screen"
        args="--ros-args --log-level $(var log_level)">
    <param from="$(var config_file)" />
  </node>
</launch>