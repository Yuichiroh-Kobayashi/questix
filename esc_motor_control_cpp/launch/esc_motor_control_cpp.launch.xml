<?xml version="1.0"?>
<!--
ESC Motor Control (C++) standalone launch file
パラメータは esc_motor_control_cpp.yaml が Single Source of Truth。
例外: joy_topic は launcher が /joy <-> /joy_gated を切替えるための唯一の override。
YAML の後に置くことで launcher からの指定が勝つようにする。
-->
<launch>
    <arg name="config_file"
         default="$(find-pkg-share esc_motor_control_cpp)/config/esc_motor_control_cpp.yaml"
         description="Path to the ESC motor control configuration YAML" />
    <arg name="joy_topic"
         default="/joy"
         description="Joy input topic (override-only, default matches YAML)" />

    <node pkg="esc_motor_control_cpp" exec="esc_motor_control_node" name="esc_motor_control" output="screen">
        <param from="$(var config_file)" />
        <param name="joy_topic" value="$(var joy_topic)" />
    </node>
</launch>
